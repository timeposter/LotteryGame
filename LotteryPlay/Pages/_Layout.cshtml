@{
    string userName = Context.Session.GetString("Username") ?? "";
}
<style>
    /* 公用账户导航样式 全站共用 */
    .top-bar {
        background: #fff;
        border-bottom: 1px solid #eee;
        padding: 8px 15px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 14px;
    }

    .red {
        color: red;
        font-weight: bold;
    }

    .account-subnav {
        background: #fef0f0;
        border-bottom: 1px solid #f8c0c0;
        padding: 6px 15px;
        font-size: 12px;
    }

        .account-subnav a {
            color:white;
            font-size: 12px;
            text-decoration: none;
            margin-right: 15px;
        }

    body {
        font-family: "Microsoft Yahei",Arial,sans-serif;
        background: #fff;
        color: #333;
        margin: 0;
        padding: 0;
    }

    
    /* 外层模块容器 */
    .account-box {
        border: 1px solid #f36;
        border-radius: 6px;
        overflow: hidden;
        width: 100%;
        margin: 0 auto;
        max-width: 1200px;
        justify-content: center;
    }
    /* 顶部红色标题栏 */
    .acc-title {
        background: #e62828;
        padding: 12px 20px;
    }

        .acc-title h2 {
            color: #fff;
            margin: 0;
            font-size: 16px;
            height: 20px;
            font-weight: normal;
        }
    /* 下方导航栏 */
    .acc-nav {
        padding: 18px 20px;
        background: #fff;
    }

        .acc-nav a {
            color: #d82424;
            font-size: 22px;
            text-decoration: none;
            margin-right: 22px;
        }

            .acc-nav a:last-child {
                margin-right: 0;
            }
   

</style>

@await Html.PartialAsync("_TopBar",ViewData)
<div class="account-box">
    <div class="acc-title">
        <h2>帐户管理</h2>
    </div>
    <div class="acc-nav">
        <a asp-page="/Account/Info">个人资料</a>
        <a asp-page="/Account/ModifyPwd">修改密码</a>
        <a asp-page="/Account/FundLog">资金明细</a>

        <a asp-page="/Account/TraceRecord">追号记录</a>
        <a asp-page="/Account/Recharge">我要充值</a>
        <a asp-page="/Account/Withdraw">我要提款</a>

        <a asp-page="/">返回投注大厅</a>
    </div>

</div>


@RenderBody()
@RenderSection("Scripts", required: false)