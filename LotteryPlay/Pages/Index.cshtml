@page
@model LotteryPlay.Pages.IndexModel
@{
    Layout = "_Layout";
}
<!-- 优先引入jQuery -->
<script src="https://cdn.jsdelivr.net/npm/jquery@3.6.4/dist/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.32/signalr.min.js"></script>
<link rel="stylesheet" href="~/css/LotteryIndex.css" asp-append-version="true" />

<style>
    body {
        background: #fcf2f2;
        font-size: 13px;
        color: #333;
    }

    /*顶部用户栏*/
    .top-user-bar {
        background: #d81828;
        color: #fff;
        padding: 8px 15px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .top-user-bar span {
        font-size: 14px;
    }

    .balance-text {
        color: #ffdd70;
        font-weight: bold;
        font-size: 15px;
    }

    .left-box {
        width: 65%;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .right-box {
        width: 35%;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    /* 左侧上区块：LOGO+当期+最新开奖 */
    .left-top {
        border: 1px solid #eee;
        padding: 15px;
        border-radius: 6px;
    }

    .logo-row {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 12px;
    }

    .lot-logo {
        width: 70px;
        height: 70px;
        background: #eee;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .period-info {
        flex: 1;
    }

    .open-result-item {
        margin-top: 10px;
        padding: 10px;
        background: #f8f8f8;
    }

    /* 左侧下区块：玩法+选号+投注追号 */
    .left-bottom {
        border: 1px solid #eee;
        padding: 15px;
        border-radius: 6px;
    }

    .play-type-group button {
        padding: 6px 10px;
        margin: 3px;
        border: 1px solid #ccc;
        background: #fff;
        cursor: pointer;
    }

    .play-type-group button.active {
        background: #09c;
        color: #fff;
        border-color: #09c;
    }

    .num-wrap {
        margin: 12px 0;
        padding: 10px;
        background: #f9f9f9;
        border-radius: 4px;
    }

    .num-row {
        margin: 8px 0;
    }

    .pos-label {
        display: inline-block;
        width: 70px;
        font-weight: bold;
    }

    /* 数字选号样式 优先级拉满 */
    span.num-item {
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        width: 32px !important;
        height: 32px !important;
        line-height: 32px !important;
        text-align: center !important;
        border: 1px solid #ccc !important;
        margin: 2px !important;
        cursor: pointer !important;
        user-select: none !important;
        background-color: #ffffff !important;
        color: #333333 !important;
        transition: all 0.2s ease !important;
    }

    span.num-item.selected {
        background: #09c !important;
        color: #ffffff !important;
        border-color: #09c !important;
        box-shadow: 0 0 5px rgba(0, 153, 204, 0.5) !important;
    }

    .pos-btn {
        padding: 3px 6px;
        margin: 2px;
        cursor: pointer;
    }

    .stat-area {
        margin: 12px 0;
    }

    .submit-btn {
        padding: 6px 12px;
        border: none;
        cursor: pointer;
        margin: 0 4px;
        border-radius: 4px;
    }

    #btnBet {
        background: #069;
        color: #fff;
        display: none;
        /* 隐藏原有单次投注按钮 */
    }

    #btnTrace {
        background: #09c;
        color: #fff;
    }

    #btnAddList {
        background: #c02020;
        color: #fff;
        font-size: 16px;
        padding: 8px 20px;
    }

    #btnClearList {
        background: #666;
        color: #fff;
    }

    #btnSubmitAll {
        background: #09c;
        color: #fff;
    }

    #traceBox {
        margin-top: 10px;
        border: 1px solid #ccc;
        padding: 10px;
        display: none;
    }

    #traceInputBox {
        display: none
    }

    /* ========== 【新增】追号列表表格样式 ========== */
    .trace-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 8px;
    }

    .trace-table th,
    .trace-table td {
        border: 1px solid #ddd;
        padding: 7px 5px;
        text-align: center;
    }

    .trace-table th {
        background: #f5f5f5;
        font-weight: normal;
    }

    /* 倍数输入框 */
    .mul-input {
        width: 60px;
        padding: 4px;
        border: 1px solid #ccc;
        text-align: center;
        border-radius: 2px;
        outline: none;
    }

    /* 金额高亮文字 */
    .trace-money {
        color: #d81828;
        font-weight: bold;
    }

    .trace-tip {
        color: #999;
        font-size: 12px;
        margin-bottom: 6px;
    }

    /* ========================================== */

    /* 投注列表区域样式 */
    .bet-list-wrap {
        margin-top: 20px;
        padding-top: 15px;
        border-top: 1px dashed #ccc;
    }

    .bet-list-wrap h4 {
        margin: 0 0 10px 0;
        font-size: 14px;
    }

    .bet-list-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
    }

    .bet-list-table th,
