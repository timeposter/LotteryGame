@page
@model LotteryPlay.Pages.IndexModel
@{
    Layout = "_Layout";
}
<!-- 优先引入jQuery -->
<script src="https://cdn.jsdelivr.net/npm/jquery@3.6.4/dist/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.32/signalr.min.js"></script>
<link rel="stylesheet" href="~/css/LotteryIndex.css" asp-append-version="true" />

<style>
    body {
        background: #fcf2f2;
        font-size: 13px;
        color: #333;
    }

    /*顶部用户栏*/
    .top-user-bar {
        background: #d81828;
        color: #fff;
        padding: 8px 15px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .top-user-bar span {
            font-size: 14px;
        }

    .balance-text {
        color: #ffdd70;
        font-weight: bold;
        font-size: 15px;
    }

    /* 全局主容器左右布局 */
    .main-container {
        display: flex;
        gap: 16px;
        max-width: 1400px;
        margin: 15px auto;
        padding: 0 10px;
    }

    .left-box {
        width: 65%;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .right-box {
        width: 35%;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    /* 左侧上区块：LOGO+当期+最新开奖 */
    .left-top {
        border: 1px solid #eee;
        padding: 15px;
        border-radius: 6px;
    }

    .logo-row {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 12px;
    }

    .lot-logo {
        width: 70px;
        height: 70px;
        background: #eee;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .period-info {
        flex: 1;
    }

    .open-result-item {
        margin-top: 10px;
        padding: 10px;
        background: #f8f8f8;
    }

    /* 左侧下区块：玩法+选号+投注追号 */
    .left-bottom {
        border: 1px solid #eee;
        padding: 15px;
        border-radius: 6px;
    }

    .play-type-group button {
        padding: 6px 10px;
        margin: 3px;
        border: 1px solid #ccc;
        background: #fff;
        cursor: pointer;
    }

        .play-type-group button.active {
            background: #09c;
            color: #fff;
            border-color: #09c;
        }

    .num-wrap {
        margin: 12px 0;
        padding: 10px;
        background: #f9f9f9;
        border-radius: 4px;
    }

    .num-row {
        margin: 8px 0;
    }

    .pos-label {
        display: inline-block;
        width: 70px;
        font-weight: bold;
    }

    /* 数字选号样式 优先级拉满 */
    span.num-item {
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        width: 32px !important;
        height: 32px !important;
        line-height: 32px !important;
        text-align: center !important;
        border: 1px solid #ccc !important;
        margin: 2px !important;
        cursor: pointer !important;
        user-select: none !important;
        background-color: #ffffff !important;
        color: #333333 !important;
        transition: all 0.2s ease !important;
    }

        span.num-item.selected {
            background: #09c !important;
            color: #ffffff !important;
            border-color: #09c !important;
            box-shadow: 0 0 5px rgba(0, 153, 204, 0.5) !important;
        }

    .pos-btn {
        padding: 3px 6px;
        margin: 2px;
        cursor: pointer;
    }

    .stat-area {
        margin: 12px 0;
    }

    .submit-btn {
        padding: 6px 12px;
        border: none;
        cursor: pointer;
        margin: 0 4px;
        border-radius: 4px;
    }

    #btnBet {
        background: #069;
        color: #fff;
        display: none; /* 隐藏原有单次投注按钮 */
    }

    #btnTrace {
        background: #09c;
        color: #fff;
    }

    #btnAddList {
        background: #c02020;
        color: #fff;
        font-size: 16px;
        padding: 8px 20px;
    }

    #btnClearList {
        background: #666;
        color: #fff;
    }

    #btnSubmitAll {
        background: #09c;
        color: #fff;
    }

    #traceBox {
        margin-top: 10px;
        border: 1px solid #ccc;
        padding: 10px;
        display: none;
    }

    #traceInputBox {
        display: none
    }

    /* ========== 【新增】追号列表表格样式 ========== */
    .trace-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 8px;
    }

        .trace-table th,
        .trace-table td {
            border: 1px solid #ddd;
            padding: 7px 5px;
            text-align: center;
        }

        .trace-table th {
            background: #f5f5f5;
            font-weight: normal;
        }

    /* 倍数输入框 */
    .mul-input {
        width: 60px;
        padding: 4px;
        border: 1px solid #ccc;
        text-align: center;
        border-radius: 2px;
        outline: none;
    }

    /* 金额高亮文字 */
    .trace-money {
        color: #d81828;
        font-weight: bold;
    }

    .trace-tip {
        color: #999;
        font-size: 12px;
        margin-bottom: 6px;
    }
    /* ========================================== */

    /* 投注列表区域样式 */
    .bet-list-wrap {
        margin-top: 20px;
        padding-top: 15px;
        border-top: 1px dashed #ccc;
    }

        .bet-list-wrap h4 {
            margin: 0 0 10px 0;
            font-size: 14px;
        }

    .bet-list-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
    }

        .bet-list-table th,
        .bet-list-table td {
            border: 1px solid #ddd;
            padding: 6px;
            text-align: center;
        }

        .bet-list-table th {
            background: #f5f5f5;
        }

    .del-btn {
        color: #d81828;
        cursor: pointer;
        text-decoration: none;
    }

    .bet-total-info {
        margin: 10px 0;
        padding: 8px;
        background: #f9f9f9;
        border-radius: 4px;
        font-weight: bold;
    }

    /* 右侧通用卡片 */
    .right-card {
        border: 1px solid #eee;
        padding: 15px;
        border-radius: 6px;
    }

        .right-card h4 {
            margin-top: 0;
            border-bottom: 1px solid #eee;
            padding-bottom: 6px;
        }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    th,
    td {
        border: 1px solid #ddd;
        padding: 6px;
        text-align: center;
    }

    /* 客服悬浮样式 */
    .kf-float {
        position: fixed;
        right: 20px;
        bottom: 80px;
        width: 50px;
        height: 50px;
        background: #09c;
        color: #fff;
        border-radius: 50%;
        text-align: center;
        line-height: 50px;
        cursor: pointer;
        z-index: 999;
    }

    .kf-box {
        position: fixed;
        right: 20px;
        bottom: 140px;
        width: 340px;
        height: 420px;
        border: 1px solid #ccc;
        background: #fff;
        display: none;
        z-index: 999;
    }

    .kf-title {
        background: #09c;
        color: #fff;
        padding: 8px;
        text-align: center;
    }

    .kf-content {
        height: 320px;
        overflow-y: auto;
        padding: 8px;
    }

    .kf-input {
        display: flex;
        padding: 8px
    }

        .kf-input input {
            flex: 1;
            padding: 6px
        }

        .kf-input button {
            background: #09c;
            border: none;
            color: #fff;
            padding: 6px 10px
        }

    .msg-left {
        text-align: left;
        margin: 4px 0
    }

    .msg-right {
        text-align: right;
        margin: 4px 0
    }

    .container-wrap {
        max-width: 1320px;
        margin: 14px auto;
        padding: 0 10px;
    }

    .main-content {
        display: flex;
        gap: 14px;
    }

    .bet-left {
        width: 72%;
        border: 1px solid #d81828;
        background: #fff;
        padding: 14px;
        border-radius: 6px;
    }

    .info-right {
        width: 28%;
    }

    .green-text {
        font-size: 30px;
        color: #00ff05;
    }

    .lottery-select {
        margin-left: 12px;
        padding: 6px;
        border: 1px solid #ccc;
        border-radius: 4px;
        background: #fff;
    }

    .lot-header {
        max-width: 1200px;
        height: 94px;
        margin-bottom: 8px;
        z-index: 1;
        background: url(/img/headbg.png) no-repeat center 0 #97000E;
        display: flex;
        gap: 8px;
        list-style: none;
        padding: 0;
        margin: 15px auto;
        justify-content: center;
        align-items: flex-end;
    }

    .box {
        display: flex;
        gap: 8px;
        list-style: none;
        padding: 0;
        margin: 0;
        justify-content: center;
        align-items: flex-end;
    }

        .box li {
            width: 65px;
            height: 65px;
            border: 0px solid;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            box-sizing: border-box;
            margin-left: 30px;
        }

            .box li img {
                width: 30px;
                height: 30px;
                object-fit: contain;
                margin-bottom: 4px;
            }

            .box li span {
                font-size: 15px;
                color: white;
            }

    .account-box {
        border: 1px solid #f36;
        border-radius: 6px;
        overflow: hidden;
        width: 100%;
        margin: 0 auto;
        max-width: 1200px;
        justify-content: center;
    }

    .acc-title {
        background: #e62828;
        padding: 12px 20px;
    }

        .acc-title h2 {
            color: #fff;
            margin: 0;
            font-size: 16px;
            height: 20px;
            font-weight: normal;
        }

    .acc-nav {
        padding: 18px 20px;
        background: #fff;
    }

        .acc-nav a {
            color: #d82424;
            font-size: 22px;
            text-decoration: none;
            margin-right: 22px;
        }

            .acc-nav a:last-child {
                margin-right: 0;
            }
    /* 调试弹窗遮罩层 */
    .debug-mask {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.6);
        z-index: 999998;
        display: none; /* 默认隐藏 */
    }

    /* 调试弹窗主体 */
    .debug-popup {
        position: fixed;
        top: 50%;
        left: 50%;
        width: 900px; /* 弹窗宽度，自行调整 */
        height: 600px; /* 弹窗高度，自行调整 */
        background: #fff;
        border: 2px solid #ccc;
        z-index: 999999;
        transform: translate(-50%, -50%); /* 居中 */
        display: none; /* 默认隐藏 */
    }

    /* 弹窗顶部栏 */
    .debug-popup-head {
        height: 40px;
        line-height: 40px;
        background: #333;
        color: #fff;
        padding: 0 15px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    /* 关闭按钮 */
    .debug-close {
        color: #fff;
        cursor: pointer;
        font-size: 18px;
        padding: 0 8px;
    }

        .debug-close:hover {
            color: #f60;
        }

    /* iframe 填充弹窗内容 */
    .debug-iframe {
        width: 100%;
        height: calc(100% - 40px);
        border: none;
    }
</style>
