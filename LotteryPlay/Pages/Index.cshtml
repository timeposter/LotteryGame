        function renderNumPanel(playName) {
            if (!playName || playName == undefined) {
                $("#numWrap").html("<div style='color:#666;text-align:center;padding:20px;'>暂无可用玩法，请切换彩种或玩法</div>");
                selectNums = "";
                recalcAllTraceMoney();
