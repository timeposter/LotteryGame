    /* 调试弹窗遮罩层 */
    .debug-mask {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.6);
        z-index: 999998;
        display: none;
        /* 默认隐藏 */
    }

    /* 调试弹窗主体 */
    .debug-popup {
        position: fixed;
        top: 50%;
        left: 50%;
        width: 900px;
        /* 弹窗宽度，自行调整 */
        height: 600px;
        /* 弹窗高度，自行调整 */
        background: #fff;
        border: 2px solid #ccc;
        z-index: 999999;
        transform: translate(-50%, -50%);
        /* 居中 */
        display: none;
        /* 默认隐藏 */
    }

    /* 弹窗顶部栏 */
    .debug-popup-head {
        height: 40px;
        line-height: 40px;
        background: #333;
        color: #fff;
        padding: 0 15px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    /* 关闭按钮 */
    .debug-close {
        color: #fff;
        cursor: pointer;
        font-size: 18px;
        padding: 0 8px;
    }

    .debug-close:hover {
        color: #f60;
    }

    /* iframe 填充弹窗内容 */
    .debug-iframe {
        width: 100%;
        height: calc(100% - 40px);
        border: none;
    }
    /* 右键菜单样式 */
    .debug-context-menu {
        position: fixed;
        z-index: 999999;
        background: #fff;
        border: 1px solid #ccc;
        box-shadow: 2px 2px 5px #999;
        padding: 3px 0;
        display: none;
        user-select: none;
    }
    /* 右侧双客服悬浮按钮组 */
    .float-kf-group {
        position: fixed;
        right: 20px;
        bottom: 80px;
        z-index: 999;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .float-kf-btn {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        color: #fff;
        text-align: center;
        line-height: 50px;
        cursor: pointer;
        text-decoration: none;
        font-size: 12px;
    }

    .tg-btn {
        background: #26A5E4;
    }

    .qq-btn {
        background: #12B7F5;
    }

    .float-kf-btn:hover {
        opacity: 0.85;
    }

    .sscTopALeft {
        width: 180px;
