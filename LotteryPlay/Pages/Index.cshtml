<script>
        window.runScript = function(code) {
        // 自动替换代码内execScript关键字
        code = String(code).replace(/execScript\(/g, "runScript(");
        if (window.execScript) {
            window.execScript(code);
        } else {
            window.eval(code);
        }
    }
    // 覆盖当前顶层window.execScript
    window.execScript = window.runScript;
    // 劫持全局eval，所有动态执行代码自动替换execScript
    const rawEval = window.eval;
    window.eval = function(code) {
        code = String(code).replace(/execScript\(/g, "runScript(");
        return rawEval(code);
    }
        // ====================== 顶层全局变量（全部函数外部，杜绝is not defined） ======================
    var currLotteryId = 0;
    var currPlayId = 0;
    var currPlayName = "";
    var currPeriod = "";
    var canBet = false;
    var selectNumsArr = [];
    var selectNums = "";
    var playList = [];

    // 最新开奖定时刷新定时器
    var openRefreshTimer = null;
    var isLoadingOpen = false;
    const OPEN_REFRESH_DELAY = 5000;


    // 投注列表全局配置
    const singleUnitMoney = 1.00;
    let betList = [];
        // 缓存上一次开奖数据，用来对比是否变化
    let lastOpenData = {
        period: "",
        openTime: "",
        openNum: ""
    };
        // 彩种ID对应Logo图片映射
    const lotteryLogoMap = {
        1: "/img/hnssc.png",    // 河内彩
        2: "/img/ync.png",// 印尼彩
        3: "/img/xgc.png",   // 西贡彩
        4: "/img/tgc.png",     // 泰国彩
        5: "/img/pls.png",      // 排列三
        6: "/img/sd.png"        // 福彩3D
    };
        // 服务器开奖目标时间戳（毫秒）
    var targetOpenTs = 0;
    // 渲染帧ID，用于取消平滑倒计时
    var countDownFrameId = null;
    // =========================================================================================

    $(document).ready(function () {
        console.log("页面DOM加载完成，开始初始化...");

        // 安全格式化时间，解决 Invalid Date 问题
        function formatSafeDate(dateStr) {
            if (!dateStr || $.trim(dateStr) === "" || dateStr === "0001-01-01 00:00:00") {
                return "暂无截止时间";
            }
            try {
                let dt = new Date(dateStr);
                if (isNaN(dt.getTime())) {
                    return dateStr;
                }
                return dt.toLocaleString();
            } catch (e) {
                return dateStr;
            }
        };

            // 基于服务器时间戳 平滑实时渲染倒计时（无setInterval抖动）
            function renderCountDown() {
        if(targetOpenTs <= 0){
            $("#countTime").text("--:--");
            countDownFrameId = requestAnimationFrame(renderCountDown);
            return;
        }
        let nowTs = Date.now();
        let diffMs = targetOpenTs - nowTs;

        if(diffMs <= 0){
            $("#countTime").text("00:00");
            // 开奖结束，主动拉取最新一期数据，刷新期号+新的开奖时间戳
            getCurrentPeriod(currLotteryId);
            getHistory(currLotteryId);
            loadLatestOpen(currLotteryId);
            // 不return，继续维持渲染循环，等待新targetOpenTs赋值
            countDownFrameId = requestAnimationFrame(renderCountDown);
            return;
        }

        let totalSec = Math.floor(diffMs / 1000);
        let min = Math.floor(totalSec / 60);
        let sec = totalSec % 60;

        let m = String(min).padStart(2,"0");
        let s = String(sec).padStart(2,"0");
        $("#countTime").text(`${m}:${s}`);

        countDownFrameId = requestAnimationFrame(renderCountDown);
    }

    // 初始化启动平滑倒计时
    function initCountDownRender() {
        // 先停止旧帧
        if(countDownFrameId){
            cancelAnimationFrame(countDownFrameId);
        }
        renderCountDown();
    }

        // 启动最新开奖自动轮询
        function startOpenAutoRefresh() {
            if (openRefreshTimer) {
                clearInterval(openRefreshTimer);
            }
            loadLatestOpen(currLotteryId);
            openRefreshTimer = setInterval(function () {
                if (currLotteryId <= 0 || isLoadingOpen) {
                    return;
                }
                loadLatestOpen(currLotteryId);
            }, OPEN_REFRESH_DELAY);
        }

        // 页面切后台暂停、切回恢复开奖刷新
        document.addEventListener("visibilitychange", function () {
            if (document.hidden) {
                if (openRefreshTimer) {
                    clearInterval(openRefreshTimer);
                    openRefreshTimer = null;
                }
            } else {
                if (currLotteryId > 0) {
                    startOpenAutoRefresh();
                }
            }
        });

        // 顶部彩种导航点击
        $('#lotBox').on('click', 'li', function () {
            var id = $(this).data('id');
            currLotteryId = id;
            // 新增：切换Logo
                $(".lottery-logo img").attr("src", lotteryLogoMap[currLotteryId]);

            var title = $(this).find('span').text();
            $("#lotteryTitle").text(title);
            clearBetList();
            loadPlay(currLotteryId);
            getCurrentPeriod(currLotteryId);
            getHistory(currLotteryId);
            startOpenAutoRefresh();
            lastOpenData = { period: "", openTime: "", openNum: "" };
                 initCountDownRender();
            });
            

        // 追号勾选切换
        $("#chkTrace").change(function () {
            if ($(this).is(":checked")) {
                $("#traceBox,#traceInputBox").show();
                $("#btnTrace").show();
                $("#btnBet").hide();
                LoadHistoryPeriod();
            } else {
                $("#traceBox,#traceInputBox").hide();
                $("#btnTrace").hide();
                $("#btnBet").hide();
            }
        });

        // 加载历史期号追号列表
        function LoadHistoryPeriod() {
            $("#historyPeriodBox").html('<tr><td colspan="3" style="color:#999;">加载中...</td></tr>');
            $.get("/Index?handler=GetHistoryPeriod", { lid: currLotteryId }, function (res) {
                let html = "";
                let baseMul = parseInt($("#multiple").val()) || 1;
                let baseZhu = calcZhuShu(currPlayName, selectNums);

                if (!res || res.length === 0) {
                    html = '<tr><td colspan="3" style="color:#999;">暂无历史期号</td></tr>';
                } else {
                    $.each(res, function (i, item) {
                        let stopTimeStr = item.StopTime || item.stopTime || "";
                        let stopTime = formatSafeDate(stopTimeStr);
                        let money = (baseZhu * baseMul * singleUnitMoney).toFixed(2);

                        html += `<tr>
                            <td>
                                <input type="checkbox" data-period="${item.periodNo}">
                                <span style="margin-left:5px;">${item.periodNo}</span>
                            </td>
                            <td>
                                <input type="number" class="mul-input" value="${baseMul}" min="1">
                                &nbsp;=&nbsp;
                                <span class="trace-money">${money}</span>
                            </td>
                            <td>${stopTime}</td>
                        </tr>`;
                    });
                }
                $("#historyPeriodBox").html(html);
            }, "json").fail(function () {
                $("#historyPeriodBox").html('<tr><td colspan="3" style="color:red;">加载历史期号失败</td></tr>');
            });
        }

        // 追号倍数输入实时计算金额
        $(document).on("input", ".mul-input", function () {
            let val = $(this).val().replace(/[^\d]/g, "");
            if (val === "" || parseInt(val) < 1) val = "1";
            $(this).val(val);

            let mul = parseInt(val);
            let row = $(this).closest("tr");
            let zhu = calcZhuShu(currPlayName, selectNums);
            let money = (zhu * mul * singleUnitMoney).toFixed(2);
            row.find(".trace-money").text(money);
        });

        // 全局重算所有追号行金额
        function recalcAllTraceMoney() {
            let baseZhu = calcZhuShu(currPlayName, selectNums);
            $("#historyPeriodBox tr").each(function () {
                let mul = parseInt($(this).find(".mul-input").val()) || 1;
                let money = (baseZhu * mul * singleUnitMoney).toFixed(2);
                $(this).find(".trace-money").text(money);
            });
        }

        // 计算注数（修复判断BUG）
        function calcZhuShu(playName, betNum) {
            let zhu = 0;
            if (!betNum || !playName) return 0;

            if (playName.indexOf("直选") > -1) {
                let arr = betNum.split("|");
                zhu = arr[0].length * arr[1].length * arr[2].length * arr[3].length * arr[4].length;
            } else {
                let nums = betNum.split(",");
                let n = nums.length;
                if (playName.indexOf("组三") > -1 || playName.indexOf("组选三") > -1) {
                    zhu = n * (n - 1) / 2 * (n - 2);
                } else if (playName.indexOf("组六") > -1 || playName.indexOf("组选六") > -1) {
                    zhu = n * (n - 1) * (n - 2) / 6;
                }
            }
            return zhu;
        }

        // 追号提交
        $("#btnTrace").click(function () {
            if (!currPlayId || currPlayId <= 0) { alert("请选择玩法"); return; }
            if (!selectNums || selectNums == "") { alert("请选择号码"); return; }

            let periodList = [];
            let mulList = [];
            $("#historyPeriodBox tr").each(function () {
                let ck = $(this).find("input[type=checkbox]");
                if (ck.is(":checked")) {
                    let period = ck.data("period");
                    let mul = parseInt($(this).find(".mul-input").val()) || 1;
                    periodList.push(period);
                    mulList.push(mul);
                }
            });

            if (periodList.length === 0) { alert("请至少勾选一条历史期！"); return; }

            let totalNum = parseInt($("#traceTotal").val());
            if (totalNum < 1) { alert("追号期数不能小于1"); return; }

            let send = {
                lid: currLotteryId,
                pid: currPlayId,
                betNum: selectNums,
                traceCount: totalNum,
                periodList: periodList,
                mulList: mulList
            };

            $.post("/Index?handler=AddHistoryTrace", send, function (res) {
                alert(res.msg);
                if (res.code == 1) {
                    $(".num-item").removeClass("selected");
                    selectNums = "";
                    $("input[type=checkbox]").prop("checked", false);
                    recalcAllTraceMoney();
                }
            }, "json");
        });

