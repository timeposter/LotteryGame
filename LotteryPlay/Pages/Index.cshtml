                    }
                    html += '<div class="pos-btn-group">';
                    html += '<button class="pos-btn" data-action="all" data-pos="' + p + '">全</button>';
                    html += '<button class="pos-btn" data-action="big" data-pos="' + p + '">大</button>';
                    html += '<button class="pos-btn" data-action="small" data-pos="' + p + '">小</button>';
                    html += '<button class="pos-btn" data-action="odd" data-pos="' + p + '">单</button>';
                    html += '<button class="pos-btn" data-action="even" data-pos="' + p + '">双</button>';
                    html += '<button class="pos-btn" data-action="clear" data-pos="' + p + '">清</button>';
                    html += '</div></div>';
                }
            } else {
                html += '<div class="num-row">';
                html += '<span class="pos-label">号码</span>';
                for (var i = 0; i <= 9; i++) {
                    html += '<span class="num-item" data-pos="99" data-num="' + i + '">' + i + '</span>';
                }
                html += '<div class="pos-btn-group">';
                html += '<button class="pos-btn" data-action="all" data-pos="99">全</button>';
                html += '<button class="pos-btn" data-action="big" data-pos="99">大</button>';
                html += '<button class="pos-btn" data-action="small" data-pos="99">小</button>';
                html += '<button class="pos-btn" data-action="odd" data-pos="99">单</button>';
                html += '<button class="pos-btn" data-action="even" data-pos="99">双</button>';
                html += '<button class="pos-btn" data-action="clear" data-pos="99">清</button>';
                html += '</div></div>';
            }
            $("#numWrap").html(html);
            selectNums = "";
            recalcAllTraceMoney();
        }

        function calcTotalMoney() {
            var multiple = parseInt($("#multiple").val()) || 1;
            recalcAllTraceMoney();
        }

        // 加载彩种列表
        function loadLottery() {
            $.get("/Index?handler=GetLotteryList", function (res) {
                if (res && res.code === 1 && res.data && res.data.length > 0) {
                    var html = "";
                    for (var i = 0; i < res.data.length; i++) {
                        var item = res.data[i];
                        html += '<div class="lottery-nav-item" data-id="' + item.id + '">' + item.lotteryName + '</div>';
                    }
                    $("#lottery-nav").html(html);

                    currLotteryId = res.data[0].id;
                    $("#lotteryNav .lottery-nav-item:first").addClass("active");
                    $("#lotteryTitle").text(res.data[0].lotteryName);

                    loadPlay(currLotteryId);
                    getCurrentPeriod(currLotteryId);
                    getHistory(currLotteryId);
                    
                    startOpenAutoRefresh();
    initCountDownRender();
} else {
                    $("#playGroup").html("<p style='color:red;margin:0;'>未获取到彩种数据，请检查接口</p>");
                }
            }, "json").fail(function () {
                $("#playGroup").html("<p style='color:red;margin:0;'>彩种接口请求失败，请检查后端服务</p>");
            });
        }

        // 加载玩法列表
        function loadPlay(lotteryId) {
            $("#playGroup").html("<p style='color:#666;margin:0;'>正在加载玩法...</p>");
            $("#numWrap").html("<p style='color:#666;margin:0;'>请稍候，加载玩法后将显示选号面板...</p>");

            $.get("/Index?handler=GetPlayList&lotteryId=" + lotteryId, function (res) {
                playList = res.data || [];
                var bonusHtml = "";
                var playHtml = "";
                let hasSelectPlay = false;
                let targetPlayId = 0;
                let targetPlayName = "";
                if (playList.length === 0) {
                    playHtml = "<p style='color:#666;margin:0;'>暂无可用玩法</p>";
                    bonusHtml = '<tr><td colspan="2" style="color:#999;">暂无奖金配置</td></tr>';
                    $("#numWrap").html("<p style='color:#666;text-align:center;padding:20px;'>暂无玩法，无法选号</p>");
                } else {
                    for (var i = 0; i < playList.length; i++) {
                        var item = playList[i];
                        let isActive = item.playName.indexOf("直选") > -1;
                        if (isActive) {
                            hasSelectPlay = true;
                            targetPlayId = item.id;
                            targetPlayName = item.playName;
                        }
                        let activeClass = isActive ? "active" : "";
                        playHtml += '<button class="' + activeClass + '" data-playid="' + item.id + '">' + item.playName + '</button>';

                        let bonusVal = Number(item.BonusAmount ?? item.bonusAmount ?? 0);
                        let bonusText = "";
                        if (isNaN(bonusVal) || bonusVal <= 0) {
                            bonusText = "<span style='color:#999;'>暂无奖金</span>";
                        } else {
                            bonusText = bonusVal + " 元";
                        }
                        bonusHtml += `<tr><td>${item.playName}</td><td>${bonusText}</td></tr>`;
                    }

                    if (hasSelectPlay) {
                        currPlayId = targetPlayId;
                        currPlayName = targetPlayName;
                    } else {
                        currPlayId = playList[0].id;
                        currPlayName = playList[0].PlayName;
                    }
                    renderNumPanel(currPlayName);
                    loadLatestOpen(lotteryId);
                }

                $("#playGroup").html(playHtml);
                $("#bonusList").html(bonusHtml);
                selectNums = "";
                $(".num-item").removeClass("selected");
                clearBetList();
            }, "json").fail(function () {
                $("#playGroup").html("<p style='color:red;margin:0;'>玩法接口请求失败，请检查后端服务</p>");
                $("#numWrap").html("<p style='color:red;text-align:center;padding:20px;'>无法加载玩法，请刷新页面重试</p>");
            });
        }

        // 渲染历史开奖表格
        function renderHistory(list) {
            var html = "";
            if (!list || list.length === 0) {
                html = '<tr><td colspan="3" class="empty-tip">暂无开奖数据</td></tr>';
            } else {
                for (var i = 0; i < list.length; i++) {
                    var item = list[i];
                    html += '<tr><td>' + item.period + '</td><td>' + item.openTime + '</td><td>' + item.openNumber + '</td></tr>';
                }
            }
            $("#historyTable tbody").html(html);
        }

            // 无感刷新核心：数据不变不渲染，更新时淡入淡出平滑切换
    function loadLatestOpen(lotId) {
        if (isLoadingOpen) return;
        isLoadingOpen = true;
        if (lastOpenData.period === "") {
            $("#newOpenData").html('<span style="color:#999;">加载中...</span>');
        }
        $.get("?handler=LatestOpen&lotId=" + lotId, function (res) {
            if (res.code === 1 && res.data) {
                let period = res.data.period;
                let openTime = res.data.openTime;
                let openNum = res.data.openNumber;
                // 数据完全一致则不刷新DOM
                if (lastOpenData.period === period && lastOpenData.openTime === openTime && lastOpenData.openNum === openNum) {
                    isLoadingOpen = false;
                    return;
                }

                // 分割号码，每一个数字单独生成 <span class="ball_blue">数字</span>
                    let numList = openNum.split(",");
    let ballDom = "";
    numList.forEach(num => {
        ballDom += `<span class="ball_blue">${num}</span>`;
    });

    let html = `
    <div style="margin:2px 0;">
        期号：<span style="color:#d81828;font-weight:bold;">${period}</span><br>
        开奖时间：${openTime}
    </div>
    <div style="margin:8px 0;font-size:14px;">
        开奖号码：
        <div class="sscTopALeftNum">
            ${ballDom}
        </div>
    </div>`;

                $("#newOpenWrap").css("opacity", "0");
                setTimeout(() => {
                    $("#newOpenData").html(html);
                    lastOpenData.period = period;
                    lastOpenData.openTime = openTime;
                    lastOpenData.openNum = openNum;
                    $("#newOpenWrap").css("opacity", "1");
                }, 300);
            } else {
                $("#newOpenData").html('<span style="color:#999;">暂无开奖记录</span>');
            }
        }, "json").fail(function () {
            $("#newOpenData").html('<span style="color:red;">开奖数据加载失败</span>');
        }).always(function () {
            isLoadingOpen = false;
        });
    }
        // 获取当前期倒计时数据
          function getCurrentPeriod(lotId) {
        $.get("/Index?handler=CurrentPeriod&lotId=" + lotId, function (res) {
            if (res.code === 1) {
                currPeriod = res.period;
                $("#currPeriod").text(res.period);
                $("#betStatus").text(res.canBet ? "正常投注" : "已截止");
                canBet = res.canBet;

                // 核心：只更新服务器开奖时间戳，不直接渲染倒计时
                targetOpenTs = res.targetOpenTs;
                    // 拉取到新时间戳，重置渲染
                initCountDownRender();
            }
        }, "json");
    }

        // 获取历史开奖列表
        function getHistory(lotId) {
            $.get("/Index?handler=LotteryHistory&lotId=" + lotId, function (res) {
                if (res.code === 1) {
                    renderHistory(res.data);
                }
            }, "json");
        }

        // 玩法按钮切换
        $(document).on("click", ".play-type-group button", function () {
            $(".play-type-group button").removeClass("active");
            $(this).addClass("active");
            currPlayId = parseInt($(this).data("playid"));
            currPlayName = $(this).text();
            renderNumPanel(currPlayName);
            loadLatestOpen(currLotteryId);
            clearBetList();
            startOpenAutoRefresh();
        });

        // 快捷选号按钮（全/大/小/单/双/清）
        $(document).on("click", ".pos-btn", function () {
            var pos = $(this).data("pos");
            var act = $(this).data("action");
            var items = $(".num-item[data-pos='" + pos + "']");

            if (act === "clear") {
                items.removeClass("selected");
            } else {
                items.removeClass("selected");
                switch (act) {
                    case "all": items.addClass("selected"); break;
                    case "big": items.filter(function () { return parseInt($(this).data("num")) >= 5; }).addClass("selected"); break;
                    case "small": items.filter(function () { return parseInt($(this).data("num")) <= 4; }).addClass("selected"); break;
                    case "odd": items.filter(function () { return parseInt($(this).data("num")) % 2 === 1; }).addClass("selected"); break;
                    case "even": items.filter(function () { return parseInt($(this).data("num")) % 2 === 0; }).addClass("selected"); break;
                }
            }
            collectSelectedNum();
        });

        // 数字点击选中/取消
        $(document).on("click", "#numWrap .num-item", function (e) {
            e.stopPropagation();
            if ($(this).hasClass("selected")) {
                $(this).removeClass("selected");
            } else {
                $(this).addClass("selected");
            }
            collectSelectedNum();
        });

        $("#multiple").change(calcTotalMoney);

        // 收集选中号码拼接格式
        function collectSelectedNum() {
            selectNumsArr = [];
            selectNums = "";

            if (currPlayName.indexOf("直选") > -1) {
                var arr = ["", "", "", "", ""];
                $(".num-item.selected").each(function () {
                    var p = parseInt($(this).data("pos"));
                    var n = $(this).data("num");
                    arr[p] += n;
                });
                selectNums = arr.join("|");
            } else {
                $(".num-item.selected").each(function () {
                    var num = $(this).data("num");
                    selectNumsArr.push(num);
                });
                selectNums = selectNumsArr.join(",");
            }
            recalcAllTraceMoney();
        }

        // 添加到投注列表
        $("#btnAddList").click(function () {
            if (!canBet) {
                alert("当前投注已截止，无法添加号码！");
                return;
            }
            if (currPlayId <= 0) {
                alert("请先选择投注玩法！");
                return;
            }
            if (!selectNums || selectNums === "") {
                alert("请先选择投注号码！");
                return;
            }

            let mul = parseInt($("#multiple").val()) || 1;
            let item = {
                playId: currPlayId,
                playName: currPlayName,
                betNum: selectNums,
                multiple: mul,
                singleMoney: singleUnitMoney,
                lineMoney: (singleUnitMoney * mul).toFixed(2)
            };

            let isExist = betList.some(x =>
                x.playId === item.playId &&
                x.betNum === item.betNum &&
                x.multiple === item.multiple
            );
            if (isExist) {
                alert("该号码组合已存在于投注列表，请勿重复添加！");
                return;
            }

            betList.push(item);
            alert("号码已成功添加到投注列表！");
            renderBetList();
        });

        // 渲染投注列表+统计金额
        function renderBetList() {
            let tbodyHtml = "";
            let totalCount = 0;
            let totalMoney = 0;

            if (betList.length === 0) {
                tbodyHtml = '<tr><td colspan="7" style="color:#999">暂无投注号码，请先选号并添加</td>';
            } else {
                for (let i = 0; i < betList.length; i++) {
                    let row = betList[i];
                    totalCount += 1;
                    totalMoney += parseFloat(row.lineMoney);

                    tbodyHtml += `
                    <tr>
                        <td>${i + 1}</td>
                        <td>${row.playName}</td>
                        <td>${row.betNum}</td>
                        <td>${row.multiple}</td>
                        <td>${row.singleMoney.toFixed(2)}</td>
                        <td>${row.lineMoney}</td>
                        <td><a class="del-btn" href="javascript:delBetItem(${i})">删除</a></td>
                    </tr>
                    `;
                }
            }

            $("#betListTable tbody").html(tbodyHtml);
            $("#totalCount").text(totalCount);
            $("#totalMoney").text(totalMoney.toFixed(2));
        }

        // 删除单条投注
        window.delBetItem = function (index) {
            betList.splice(index, 1);
            renderBetList();
        }

        // 清空投注列表
        $("#btnClearList").click(function () {
            if (betList.length === 0) {
                alert("列表已为空！");
                return;
            }
            if (!confirm("确定要清空所有投注号码吗？")) return;
            clearBetList();
        });

        function clearBetList() {
            betList = [];
            renderBetList();
        }

        // 批量确认投注提交
        $("#btnSubmitAll").click(function () {
            if (!canBet) {
                alert("投注已截止，无法提交！");
                return;
            }
            if (betList.length === 0) {
                alert("投注列表为空，请先添加号码！");
                return;
            }
            if (!currPeriod) {
                alert("暂无当前期号！");
                return;
            }

            let postData = {
                lotteryId: currLotteryId,
                period: currPeriod,
                betItems: JSON.stringify(betList)
            };

            $.post("/Index?handler=Bet", postData, function (res) {
                alert(res.msg);
                if (res.code === 1) {
                    clearBetList();
                    $(".num-item").removeClass("selected");
                    selectNums = "";
                }
            }, "json").fail(function (xhr) {
                alert("投注请求失败，接口异常！状态码：" + xhr.status);
            });
        });

        // 页面初始化执行
        loadLottery();
        setTimeout(function () {
            $('#lotBox li[data-id="1"]').click();
        }, 200);

        // ========== 此处为 $(document).ready 内部末尾，在这里插入30秒校准定时器 ==========
        // 每30秒同步一次接口校准倒计时，消除本地计时误差，不闪烁
        setInterval(function(){
            if(currLotteryId>0){
                getCurrentPeriod(currLotteryId);
            }
        },30000);

        // 页面关闭销毁所有定时器
        $(window).on("beforeunload", function () {
            
                // 销毁倒计时渲染帧
        if(countDownFrameId){
            cancelAnimationFrame(countDownFrameId);
        }
        if (openRefreshTimer) {
            clearInterval(openRefreshTimer);
        }
        });
    });

    // 调试弹窗全局DOM
    var debugMask = document.getElementById('debugMask');
    var debugPopup = document.getElementById('debugPopup');
    var debugCloseBtn = document.getElementById('debugCloseBtn');
    debugCloseBtn.onclick = function () {
        debugMask.style.display = 'none';
        debugPopup.style.display = 'none';
    };

    // 右键调试菜单
    document.addEventListener('contextmenu', function (e) {
        e = e || window.event;
        let menu = document.querySelector('.debug-context-menu');
        if (!menu) {
            menu = document.createElement('div');
            menu.className = 'debug-context-menu';
            menu.style.cssText = `
                position: fixed;
                z-index: 999999;
                background: #fff;
                border: 1px solid #ccc;
                box-shadow: 2px 2px 5px #999;
                padding: 3px 0;
                display: none;
                user-select: none;
            `;
            let splitLine = document.createElement('div');
            splitLine.style.height = '1px';
            splitLine.style.background = '#ccc';
            splitLine.style.margin = '2px 0';
            let debugItem = document.createElement('div');
            debugItem.innerText = 'DeBug 调试工具';
            debugItem.style.cssText = `
                padding: 5px 18px;
                font-size: 14px;
                cursor: pointer;
                white-space: nowrap;
            `;
            debugItem.onmouseover = function () { this.style.background = '#e6e6e6'; };
            debugItem.onmouseout = function () { this.style.background = 'transparent'; };
            debugItem.onclick = function () {
                debugMask.style.display = 'block';
                debugPopup.style.display = 'block';
                menu.style.display = 'none';
            };
            menu.appendChild(splitLine);
            menu.appendChild(debugItem);
            document.body.appendChild(menu);
        }
        let mouseX = e.clientX || e.pageX;
        let mouseY = e.clientY || e.pageY;
        const winWidth = document.documentElement.clientWidth;
        const winHeight = document.documentElement.clientHeight;
        if (mouseX + 180 > winWidth) mouseX = winWidth - 180;
        if (mouseY + 80 > winHeight) mouseY = winHeight - 80;
        menu.style.left = mouseX + 'px';
        menu.style.top = mouseY + 'px';
        menu.style.display = 'block';
        function hideMenu() {
            menu.style.display = 'none';
            document.removeEventListener('click', hideMenu);
        }
        document.removeEventListener('click', hideMenu);
        document.addEventListener('click', hideMenu);
    });
</script>