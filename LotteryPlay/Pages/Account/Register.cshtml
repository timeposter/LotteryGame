@{
    Layout = null;
}
<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: "Microsoft Yahei",sans-serif;
    }

    body {
        width: 100vw;
        height: 100vh;
        background: linear-gradient(135deg,#0c0c20,#1a1030);
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    /* 背景浮动彩球 */
    .ball-item {
        position: absolute;
        border-radius: 50%;
        opacity: 0.6;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
    }
    /* 登录卡片容器 */
    .login-box {
        width: 420px;
        background: #222238;
        border-radius: 22px;
        padding: 30px 32px;
        border: 1px solid #554878;
        z-index: 9;
    }
    /* 顶部品牌 */
    .brand-top {
        display: flex;
        justify-content: center;
        gap: 12px;
        margin-bottom: 20px;
    }

        .brand-top span {
            width: 52px;
            height: 52px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: bold;
        }

    .b1 {
        background: #e84444;
    }

    .b2 {
        background: #f7bc79;
    }

    .b3 {
        background: #ffcc22;
    }

    .b4 {
        background: #f7bc79;
    }

    .b5 {
        background: #54a8f2;
    }

    .login-title {
        text-align: center;
        color: #fff;
        font-size: 32px;
        font-weight: bold;
        letter-spacing: 2px;
    }

    .sub-title {
        text-align: center;
        color: #c9c9e2;
        font-size: 14px;
        margin: 6px 0 26px;
        position: relative;
    }

        .sub-title::before, .sub-title::after {
            content: "——";
            margin: 0 12px;
            color: #ffcc22;
        }
    /* 合作商模块 */
    .partner-wrap {
        display: flex;
        justify-content: space-around;
        margin-bottom: 30px;
    }

    .partner-item {
        text-align: center;
        color: #ddd;
        font-size: 12px;
    }

        .partner-item img {
            width: 54px;
            height: 54px;
            object-fit: contain;
            margin-bottom: 6px;
            border-radius: 50%;
            background: #fff;
        }
    /* 表单 */
    .form-item {
        margin-bottom: 18px;
    }

        .form-item label {
            display: block;
            color: #ddd;
            font-size: 15px;
            margin-bottom: 6px;
        }

    .input-wrap {
        position: relative;
    }

        .input-wrap input {
            width: 100%;
            height: 46px;
            background: #32324e;
            border: 1px solid #4c4c70;
            border-radius: 10px;
            padding: 0 42px;
            color: #fff;
            font-size: 15px;
        }

            .input-wrap input:focus {
                outline: none;
                border-color: #ffcc22;
            }

        .input-wrap .icon-left {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #aaa;
        }

    .eye-btn {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #aaa;
        cursor: pointer;
    }

    .reg-link {
        text-align: right;
        margin: -8px 0 22px;
    }

        .reg-link a {
            color: #ffcc22;
            font-size: 14px;
            text-decoration: none;
        }
    /* 按钮 */
    .login-btn {
        width: 100%;
        height: 52px;
        background: linear-gradient(90deg,#d82020,#f23b3b);
        border: none;
        border-radius: 12px;
        color: #fff;
        font-size: 18px;
        font-weight: bold;
        cursor: pointer;
        margin-bottom: 14px;
    }

    .app-btn {
        width: 100%;
        height: 52px;
        background: linear-gradient(90deg,#06b986,#20d29b);
        border: none;
        border-radius: 12px;
        color: #fff;
        font-size: 17px;
        cursor: pointer;
        position: relative;
    }

    .app-tag {
        position: absolute;
        right: 16px;
        top: -8px;
        background: #ffcc22;
        color: #222;
        font-size: 12px;
        padding: 2px 6px;
        border-radius: 4px;
    }

    .copyright {
        text-align: center;
        color: #888;
        font-size: 13px;
        margin-top: 22px;
    }
</style>
<body>
    <!-- 背景彩球（随机点位，可按需增删） -->
    <div class="ball-item" style="width:50px;height:50px;background:#2974bb;top:18%;left:7%;">2</div>
    <div class="ball-item" style="width:72px;height:72px;background:#279968;top:14%;left:21%;">3</div>
    <div class="ball-item" style="width:65px;height:65px;background:#bb893c;top:12%;right:8%;">12</div>
    <div class="ball-item" style="width:42px;height:42px;background:#279968;top:26%;right:9%;">2</div>
    <div class="ball-item" style="width:38px;height:38px;background:#7952b3;top:42%;left:2%;">11</div>
    <div class="ball-item" style="width:80px;height:80px;background:#bb893c;top:49%;left:27%;">24</div>
    <div class="ball-item" style="width:66px;height:66px;background:#279968;top:56%;left:14%;">21</div>
    <div class="ball-item" style="width:58px;height:58px;background:#c73c3c;top:68%;left:12%;">19</div>
    <div class="ball-item" style="width:62px;height:62px;background:#279968;top:73%;left:7%;">15</div>
    <div class="ball-item" style="width:48px;height:48px;background:#2974bb;top:75%;left:10%;">8</div>
    <div class="ball-item" style="width:52px;height:52px;background:#2974bb;top:82%;left:19%;">20</div>
    <div class="ball-item" style="width:56px;height:56px;background:#c73c3c;top:86%;left:23%;">25</div>
    <div class="ball-item" style="width:45px;height:45px;background:#c73c3c;top:93%;left:14%;">7</div>
    <div class="ball-item" style="width:40px;height:40px;background:#c73c3c;top:91%;left:18%;">1</div>
    <div class="ball-item" style="width:50px;height:50px;background:#c73c3c;top:76%;right:29%;">13</div>
    <div class="ball-item" style="width:44px;height:44px;background:#7952b3;top:78%;right:34%;">23</div>
    <div class="ball-item" style="width:68px;height:68px;background:#279968;top:71%;right:5%;">9</div>
    <div class="ball-item" style="width:60px;height:60px;background:#bb893c;top:90%;right:10%;">10</div>
    <div class="ball-item" style="width:42px;height:42px;background:#ffcc22;top:95%;right:3%;">6</div>
    <div class="ball-item" style="width:75px;height:75px;background:#bb893c;bottom:2%;left:29%;">22</div>

    <!-- 登录主体卡片 -->
    <div class="login-box">
        <div class="brand-top">
            <span class="b1">金</span>
            <span class="b2">沙</span>
            <span class="b3">★</span>
            <span class="b4">娱</span>
            <span class="b5">乐</span>
        </div>
        <h1 class="login-title">会员登录</h1>
        <div class="sub-title">公平·安全·快捷</div>

        <!-- 合作赞助商 -->
        <div class="partner-wrap">
            <div class="partner-item">
                <img src="~/img/ala.png" alt="阿拉维斯">
                <div>阿拉维斯<br /><small>官方胸前赞助商</small></div>
            </div>
            <div class="partner-item">
                <img src="~/img/como.png" alt="科莫">
                <div>科莫<br /><small>官方区域合作伙伴</small></div>
            </div>
            <div class="partner-item">
                <img src="~/img/toti.png" alt="托蒂">
                <div>弗朗切斯科·托蒂<br /><small>亚洲独家品牌形象大使</small></div>
            </div>
        </div>

        <!-- 登录表单 -->
        <form id="loginForm" asp-page-handler="Login" method="post">
            <div class="form-item">
                <label>用户名</label>
                <div class="input-wrap">
                    <span class="icon-left">👤</span>
                    <input type="text" name="UserName" placeholder="请输入用户名" required>
                </div>
            </div>
            <div class="form-item">
                <label>密码</label>
                <div class="input-wrap">
                    <span class="icon-left">🔒</span>
                    <input type="password" id="pwdInput" name="Pwd" placeholder="请输入密码" required>
                    <span class="eye-btn" id="eyeBtn">👁</span>
                </div>
            </div>
            <div class="reg-link">
                <a asp-page="/Register">用户注册></a>
            </div>
            <button type="submit" class="login-btn">登 录</button>
        </form>

        <button class="app-btn">
            🤖 下载 Android APP
            <span class="app-tag">金沙</span>
        </button>

        <div class="copyright">Copyright © 2026 金沙娱乐 All Rights Reserved</div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        //密码显隐切换（原有功能保留）
        $("#eyeBtn").click(function(){
            var inp = $("#pwdInput");
            if(inp.attr("type")=="password"){
                inp.attr("type","text");
                $(this).text("🙈");
            }else{
                inp.attr("type","password");
                $(this).text("👁");
            }
        })
        //APP下载按钮点击逻辑可自行绑定跳转下载地址
        $(".app-btn").click(function(){
            //window.location.href = "apk下载地址";
            alert("跳转APP下载页");
        })
    </script>
</body>