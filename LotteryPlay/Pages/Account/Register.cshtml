@page "/Account/Register"
@model LotteryPlay.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "账号注册";
    Layout = null;
}

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Microsoft Yahei", sans-serif;
        }

        body {
            background: #0b0b16;
            background-image: radial-gradient(circle at 50% 20%, #251a40 0%, #0b0b16 70%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        /* 注册主卡片 */
        .reg-card {
            width: 460px;
            background: #17172b;
            border: 1px solid #b88a2066;
            border-radius: 16px;
            padding: 35px 30px;
            box-shadow: 0 0 40px rgba(216, 32, 32, 0.15);
        }

        .reg-header {
            text-align: center;
            margin-bottom: 30px;
        }

            .reg-header h2 {
                color: #d4af37;
                font-size: 28px;
                letter-spacing: 2px;
                margin-bottom: 8px;
            }

            .reg-header p {
                color: #999;
                font-size: 14px;
            }

        /* 表单通用行 */
        .form-row {
            margin-bottom: 18px;
        }

            .form-row label {
                display: block;
                color: #e0e0e0;
                font-size: 14px;
                margin-bottom: 7px;
            }

        .input-box {
            position: relative;
        }

            .input-box input,
            .input-box select {
                width: 100%;
                height: 48px;
                background: #24243f;
                border: 1px solid #3d3d62;
                border-radius: 8px;
                padding: 0 16px;
                color: #fff;
                font-size: 15px;
            }

                .input-box input:focus,
                .input-box select:focus {
                    outline: none;
                    border-color: #d4af37;
                }

        /* 密码眼睛按钮 */
        .eye-toggle {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #aaa;
            cursor: pointer;
            font-size: 18px;
        }

        /* 验证码行 */
        .captcha-row {
            display: flex;
            gap: 12px;
            align-items: center;
        }

        .captcha-tip {
            color: #ffcc22;
            font-size: 16px;
            white-space: nowrap;
        }

        .captcha-input {
            flex: 1;
        }

        /* 错误提示 */
        .error-tip {
            color: #ff5c5c;
            font-size: 13px;
            margin-top: 4px;
            display: block;
        }

        /* 协议勾选 */
        .agree-row {
            margin: 22px 0;
            display: flex;
            align-items: flex-start;
            gap: 8px;
        }

            .agree-row label {
                color: #aaa;
                font-size: 13px;
                line-height: 1.5;
            }

            .agree-row a {
                color: #ffcc22;
                text-decoration: none;
            }

        /* 注册按钮 */
        .submit-btn {
            width: 100%;
            height: 50px;
            background: linear-gradient(90deg, #d82020, #f13838);
            border: none;
            border-radius: 8px;
            color: #fff;
            font-size: 17px;
            font-weight: bold;
            cursor: pointer;
        }

            .submit-btn:hover {
                opacity: 0.92;
            }

        /* 底部跳转登录 */
        .bottom-link {
            text-align: center;
            margin-top: 20px;
            color: #999;
            font-size: 14px;
        }

            .bottom-link a {
                color: #ffcc22;
                text-decoration: none;
            }
    </style>
</head>
<body>
    <div class="reg-card">
        <div class="reg-header">
            <h2>会员注册</h2>
            <p>安全稳定 · 资金秒存秒提</p>
        </div>

        <form method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="error-tip"></div>

            <!-- 用户名 -->
            <div class="form-row">
                <label asp-for="Input.Username">用户名</label>
                <div class="input-box">
                    <input asp-for="Input.Username" placeholder="请设置登录用户名" autocomplete="off" />
                </div>
                <span asp-validation-for="Input.Username" class="error-tip"></span>
            </div>

            <!-- 登录密码 -->
            <div class="form-row">
                <label asp-for="Input.LoginPassword">登录密码</label>
                <div class="input-box">
                    <input asp-for="Input.LoginPassword" id="pwdLogin" type="password" placeholder="6-16位字母+数字" />
                    <span class="eye-toggle" data-target="pwdLogin">👁</span>
                </div>
                <span asp-validation-for="Input.LoginPassword" class="error-tip"></span>
            </div>

            <!-- 提款密码 -->
            <div class="form-row">
                <label asp-for="Input.WithdrawPassword">提款密码</label>
                <div class="input-box">
                    <input asp-for="Input.WithdrawPassword" id="pwdWithdraw" type="password" placeholder="资金提现独立密码" />
                    <span class="eye-toggle" data-target="pwdWithdraw">👁</span>
                </div>
                <span asp-validation-for="Input.WithdrawPassword" class="error-tip"></span>
            </div>

            <!-- 真实姓名 -->
            <div class="form-row">
                <label asp-for="Input.RealName">真实姓名</label>
                <div class="input-box">
                    <input asp-for="Input.RealName" placeholder="提现收款实名必须一致" />
                </div>
                <span asp-validation-for="Input.RealName" class="error-tip"></span>
            </div>

            <!-- 收款方式 -->
            <div class="form-row">
                <label asp-for="Input.WithdrawMethod">收款方式</label>
                <div class="input-box">
                    <select asp-for="Input.WithdrawMethod">
                        <option value="">请选择收款方式</option>
                        <option value="银行卡">银行卡</option>
                        <option value="支付宝">支付宝</option>
                        <option value="微信">微信</option>
                    </select>
                </div>
                <span asp-validation-for="Input.WithdrawMethod" class="error-tip"></span>
            </div>

            <!-- 收款账号 -->
            <div class="form-row">
                <label asp-for="Input.WithdrawAccount">收款账号</label>
                <div class="input-box">
                    <input asp-for="Input.WithdrawAccount" placeholder="填写完整收款账号" />
                </div>
                <span asp-validation-for="Input.WithdrawAccount" class="error-tip"></span>
            </div>

            <!-- 省市 -->
            <div class="form-row">
                <label>所在省市</label>
                <div style="display:flex;gap:10px;">
                    <div class="input-box" style="flex:1;">
                        <input asp-for="Input.Province" placeholder="省份" />
                    </div>
                    <div class="input-box" style="flex:1;">
                        <input asp-for="Input.City" placeholder="城市" />
                    </div>
                </div>
            </div>

            <!-- QQ号码 -->
            <div class="form-row">
                <label asp-for="Input.QQ">联系QQ</label>
                <div class="input-box">
                    <input asp-for="Input.QQ" placeholder="客服联系备用" />
                </div>
                <span asp-validation-for="Input.QQ" class="error-tip"></span>
            </div>

            <!-- 加法验证码（后端原有逻辑完整保留） -->
            <div class="form-row">
                <label>安全验证</label>
                <div class="captcha-row">
                    <span class="captcha-tip">@Model.CaptchaNum1 + @Model.CaptchaNum2 = ?</span>
                    <div class="input-box captcha-input">
                        <input asp-for="Input.CaptchaResult" placeholder="填写计算结果" autocomplete="off" />
                    </div>
                </div>
                <span asp-validation-for="Input.CaptchaResult" class="error-tip"></span>
            </div>

            <!-- 用户协议勾选 -->
            <div class="agree-row">
                <input type="checkbox" id="agreeRule" required>
                <label for="agreeRule">我已年满18周岁，并已阅读、同意<a href="#">用户服务协议</a>与隐私条款</label>
            </div>

            <!-- 注册提交按钮 -->
            <button type="submit" class="submit-btn">立即注册账号</button>
        </form>

        <!-- 返回登录链接 -->
        <div class="bottom-link">
            已有账号？<a asp-page="Login">前往登录</a>
        </div>
    </div>

    <script>
        // 多密码框显隐切换通用逻辑
        $(".eye-toggle").click(function () {
            let targetId = $(this).attr("data-target");
            let inputObj = $("#" + targetId);
            if (inputObj.attr("type") === "password") {
                inputObj.attr("type", "text");
                $(this).text("🙈");
            } else {
                inputObj.attr("type", "password");
                $(this).text("👁");
            }
        });
    </script>
</body>
</html>