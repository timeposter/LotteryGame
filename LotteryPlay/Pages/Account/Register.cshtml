@page "/Account/Register"
@model LotteryPlay.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "账号注册";
    Layout = null;
}

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Microsoft Yahei", sans-serif;
        }

        body {
            background: #0b0b16;
            background-image: radial-gradient(circle at 50% 20%, #251a40 0%, #0b0b16 70%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        /* 注册主卡片 */
        .reg-card {
            width: 460px;
            background: #17172b;
            border: 1px solid #b88a2066;
            border-radius: 16px;
            padding: 35px 30px;
            box-shadow: 0 0 40px rgba(216, 32, 32, 0.15);
        }

        .reg-header {
            text-align: center;
            margin-bottom: 30px;
        }

            .reg-header h2 {
                color: #d4af37;
                font-size: 28px;
                letter-spacing: 2px;
                margin-bottom: 8px;
            }

            .reg-header p {
                color: #999;
                font-size: 14px;
            }

        /* 表单通用行 */
        .form-row {
            margin-bottom: 18px;
        }

            .form-row label {
                display: block;
                color: #e0e0e0;
                font-size: 14px;
                margin-bottom: 7px;
            }

        .input-box {
            position: relative;
        }

            .input-box input,
            .input-box select {
                width: 100%;
                height: 48px;
                background: #24243f;
                border: 1px solid #3d3d62;
                border-radius: 8px;
                padding: 0 16px;
                color: #fff;
                font-size: 15px;
            }

                .input-box input:focus,
                .input-box select:focus {
                    outline: none;
                    border-color: #d4af37;
                }

        /* 密码眼睛按钮 */
        .eye-toggle {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #aaa;
            cursor: pointer;
            font-size: 18px;
        }

        /* 验证码行 */
        .captcha-row {
            display: flex;
            gap: 12px;
            align-items: center;
        }

        .captcha-tip {
            color: #ffcc22;
            font-size: 16px;
            white-space: nowrap;
        }

        .captcha-input {
            flex: 1;
        }

        /* 错误提示 */
        .error-tip {
            color: #ff5c5c;
            font-size: 13px;
            margin-top: 4px;
            display: block;
        }

        /* 协议勾选 */
        .agree-row {
            margin: 22px 0;
            display: flex;
            align-items: flex-start;
            gap: 8px;
        }

            .agree-row label {
                color: #aaa;
                font-size: 13px;
                line-height: 1.5;
            }

            .agree-row a {
                color: #ffcc22;
                text-decoration: none;
            }

        /* 注册按钮 */
        .submit-btn {
            width: 100%;
            height: 50px;
            background: linear-gradient(90deg, #d82020, #f13838);
            border: none;
            border-radius: 8px;
            color: #fff;
            font-size: 17px;
            font-weight: bold;
            cursor: pointer;
        }

            .submit-btn:hover {
                opacity: 0.92;
            }

        /* 底部跳转登录 */
        .bottom-link {
            text-align: center;
            margin-top: 20px;
            color: #999;
            font-size: 14px;
        }

            .bottom-link a {
                color: #ffcc22;
                text-decoration: none;
            }
    </style>
</head>
<body>
    <div class="reg-card">
        <div class="reg-header">
            <h2>会员注册</h2>
            <p>安全稳定 · 资金秒存秒提</p>
        </div>

        <form id="regForm" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="error-tip"></div>

            <!-- 用户名 -->
            <div class="form-row">
                <label asp-for="Input.Username">用户名</label>
                <div class="input-box">
                    <input asp-for="Input.Username" placeholder="请设置登录用户名" autocomplete="off" />
                </div>
                <span asp-validation-for="Input.Username" class="error-tip"></span>
            </div>

            <!-- 登录密码 -->
            <div class="form-row">
                <label asp-for="Input.LoginPassword">登录密码</label>
                <div class="input-box">
                    <input asp-for="Input.LoginPassword" id="pwdLogin" type="password" placeholder="6-16位字母+数字" />
                    <span class="eye-toggle" data-target="pwdLogin">👁</span>
                </div>
                <span asp-validation-for="Input.LoginPassword" class="error-tip"></span>
            </div>

            <!-- 确认登录密码 -->
            <div class="form-row">
                <label>确认登录密码</label>
                <div class="input-box">
                    <input id="pwdLoginConfirm" name="Input.LoginPasswordConfirm" type="password" placeholder="再次输入登录密码" />
                    <span class="eye-toggle" data-target="pwdLoginConfirm">👁</span>
                </div>
                <span class="error-tip" id="loginPwdTip"></span>
            </div>

            <!-- 提款密码 -->
            <div class="form-row">
                <label asp-for="Input.WithdrawPassword">提款密码</label>
                <div class="input-box">
                    <input asp-for="Input.WithdrawPassword"  id="pwdWithdraw" type="password" placeholder="资金提现独立密码" />
                    <span class="eye-toggle" data-target="pwdWithdraw">👁</span>
                </div>
                <span asp-validation-for="Input.WithdrawPassword" class="error-tip"></span>
            </div>

            <!-- 确认提款密码 -->
            <div class="form-row">
                <label>确认提款密码</label>
                <div class="input-box">
                    <input id="pwdWithdrawConfirm" name="Input.WithdrawPasswordConfirm" type="password" placeholder="再次输入提款密码" />
                    <span class="eye-toggle" data-target="pwdWithdrawConfirm">👁</span>
                </div>
                <span class="error-tip" id="withdrawPwdTip"></span>
            </div>

            <!-- 真实姓名 -->
            <div class="form-row">
                <label asp-for="Input.RealName">真实姓名</label>
                <div class="input-box">
                    <input asp-for="Input.RealName" placeholder="提现收款实名必须一致" />
                </div>
                <span asp-validation-for="Input.RealName" class="error-tip"></span>
            </div>

            <!-- 收款方式 仅支付宝/USDT -->
            <div class="form-row">
                <label asp-for="Input.WithdrawMethod">收款方式</label>
                <div class="input-box">
                    <select asp-for="Input.WithdrawMethod">
                        <option value="">请选择收款方式</option>
                        <option value="支付宝">支付宝</option>
                        <option value="USDT">USDT（泰达币）</option>
                    </select>
                </div>
                <span asp-validation-for="Input.WithdrawMethod" class="error-tip"></span>
            </div>

            <!-- 收款账号 -->
            <div class="form-row">
                <label asp-for="Input.WithdrawAccount">收款账号</label>
                <div class="input-box">
                    <input id="withdrawAccountInput" asp-for="Input.WithdrawAccount" placeholder="请先选择收款方式" />
                </div>
                <span asp-validation-for="Input.WithdrawAccount" class="error-tip"></span>
            </div>

            <!-- 所在省市 下拉联动 -->
            <div class="form-row">
                <label>所在省市</label>
                <div style="display:flex;gap:10px;">
                    <div class="input-box" style="flex:1;">
                        <select id="provinceSel" asp-for="Input.Province">
                            <option value="">选择省份</option>
                        </select>
                    </div>
                    <div class="input-box" style="flex:1;">
                        <select id="citySel" asp-for="Input.City">
                            <option value="">选择城市</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- QQ号码 -->
            <div class="form-row">
                <label asp-for="Input.QQ">联系QQ</label>
                <div class="input-box">
                    <input asp-for="Input.QQ" placeholder="客服联系备用" />
                </div>
                <span asp-validation-for="Input.QQ" class="error-tip"></span>
            </div>

            <!-- 加法验证码 -->
            <div class="form-row">
                <label>安全验证</label>
                <div class="captcha-row">
                    <span class="captcha-tip">@Model.CaptchaNum1 + @Model.CaptchaNum2 = ?</span>
                    <div class="input-box captcha-input">
                        <input asp-for="Input.CaptchaResult" placeholder="填写计算结果" autocomplete="off" />
                    </div>
                </div>
                <span asp-validation-for="Input.CaptchaResult" class="error-tip"></span>
            </div>

            <!-- 用户协议勾选 -->
            <div class="agree-row">
                <input type="checkbox" id="agreeRule" required>
                <label for="agreeRule">我已年满18周岁，并已阅读、同意<a href="#">用户服务协议</a>与隐私条款</label>
            </div>

            <!-- 注册提交按钮 -->
            <button type="submit" class="submit-btn">立即注册账号</button>
        </form>

        <!-- 返回登录链接 -->
        <div class="bottom-link">
            已有账号？<a asp-page="Login">前往登录</a>
        </div>
    </div>

    <script>
        // 全国省市静态数据源
        const areaData = {
            "北京市": ["北京市"],
            "天津市": ["天津市"],
            "上海市": ["上海市"],
            "重庆市": ["重庆市"],
            "河北省": ["石家庄市","唐山市","秦皇岛市","邯郸市","邢台市","保定市","张家口市","承德市","沧州市","廊坊市","衡水市"],
            "山西省": ["太原市","大同市","阳泉市","长治市","晋城市","朔州市","晋中市","运城市","忻州市","临汾市","吕梁市"],
            "辽宁省": ["沈阳市","大连市","鞍山市","抚顺市","本溪市","丹东市","锦州市","营口市","阜新市","辽阳市","盘锦市","铁岭市","朝阳市","葫芦岛市"],
            "吉林省": ["长春市","吉林市","四平市","辽源市","通化市","白山市","松原市","白城市"],
            "黑龙江省": ["哈尔滨市","齐齐哈尔市","鸡西市","鹤岗市","双鸭山市","大庆市","伊春市","佳木斯市","七台河市","牡丹江市","黑河市","绥化市"],
            "江苏省": ["南京市","无锡市","徐州市","常州市","苏州市","南通市","连云港市","淮安市","盐城市","扬州市","镇江市","泰州市","宿迁市"],
            "浙江省": ["杭州市","宁波市","温州市","嘉兴市","湖州市","绍兴市","金华市","衢州市","舟山市","台州市","丽水市"],
            "安徽省": ["合肥市","芜湖市","蚌埠市","淮南市","马鞍山市","淮北市","铜陵市","安庆市","黄山市","滁州市","阜阳市","宿州市","六安市","亳州市","池州市","宣城市"],
            "福建省": ["福州市","厦门市","莆田市","三明市","泉州市","漳州市","南平市","龙岩市","宁德市"],
            "江西省": ["南昌市","景德镇市","萍乡市","九江市","新余市","鹰潭市","赣州市","吉安市","宜春市","抚州市","上饶市"],
            "山东省": ["济南市","青岛市","淄博市","枣庄市","东营市","烟台市","潍坊市","济宁市","泰安市","威海市","日照市","临沂市","德州市","聊城市","滨州市","菏泽市"],
            "河南省": ["郑州市","开封市","洛阳市","平顶山市","安阳市","鹤壁市","新乡市","焦作市","濮阳市","许昌市","漯河市","三门峡市","南阳市","商丘市","信阳市","周口市","驻马店市"],
            "湖北省": ["武汉市","黄石市","十堰市","宜昌市","襄阳市","鄂州市","荆门市","孝感市","荆州市","黄冈市","咸宁市","随州市"],
            "湖南省": ["长沙市","株洲市","湘潭市","衡阳市","邵阳市","岳阳市","常德市","张家界市","益阳市","郴州市","永州市","怀化市","娄底市","湘西土家族苗族自治州"],
            "广东省": ["广州市","深圳市","珠海市","汕头市","佛山市","韶关市","湛江市","肇庆市","江门市","茂名市","惠州市","梅州市","汕尾市","河源市","阳江市","清远市","东莞市","中山市","潮州市","揭阳市","云浮市"],
            "海南省": ["海口市","三亚市","三沙市","儋州市"],
            "四川省": ["成都市","自贡市","攀枝花市","泸州市","德阳市","绵阳市","广元市","遂宁市","内江市","乐山市","南充市","眉山市","宜宾市","广安市","达州市","雅安市","巴中市","资阳市"],
            "贵州省": ["贵阳市","六盘水市","遵义市","安顺市","毕节市","铜仁市"],
            "云南省": ["昆明市","曲靖市","玉溪市","保山市","昭通市","丽江市","普洱市","临沧市","楚雄彝族自治州","红河哈尼族彝族自治州","文山壮族苗族自治州","西双版纳傣族自治州","大理白族自治州","德宏傣族景颇族自治州","怒江傈僳族自治州","迪庆藏族自治州"],
            "陕西省": ["西安市","铜川市","宝鸡市","咸阳市","渭南市","延安市","汉中市","榆林市","安康市","商洛市"],
            "甘肃省": ["兰州市","嘉峪关市","金昌市","白银市","天水市","武威市","张掖市","平凉市","酒泉市","庆阳市","定西市","陇南市"],
            "青海省": ["西宁市","海东市"],
            "台湾省": ["台北市","新北市","桃园市","台中市","台南市","高雄市"],
            "内蒙古自治区": ["呼和浩特市","包头市","乌海市","赤峰市","通辽市","鄂尔多斯市","呼伦贝尔市","巴彦淖尔市","乌兰察布市"],
            "广西壮族自治区": ["南宁市","柳州市","桂林市","梧州市","北海市","防城港市","钦州市","贵港市","玉林市","百色市","贺州市","河池市","来宾市","崇左市"],
            "西藏自治区": ["拉萨市","日喀则市","昌都市","林芝市","山南市","那曲市","阿里地区"],
            "宁夏回族自治区": ["银川市","石嘴山市","吴忠市","固原市","中卫市"],
            "新疆维吾尔自治区": ["乌鲁木齐市","克拉玛依市","吐鲁番市","哈密市","昌吉回族自治州","博尔塔拉蒙古自治州","巴音郭楞蒙古自治州","阿克苏地区","克孜勒苏柯尔克孜自治州","喀什地区","和田地区","伊犁哈萨克自治州","塔城地区","阿勒泰地区"],
            "香港特别行政区": ["香港"],
            "澳门特别行政区": ["澳门"]
        };

        const $prov = $("#provinceSel");
        const $city = $("#citySel");

        // 初始化省份下拉
        function initProvince() {
            let html = '<option value="">选择省份</option>';
            Object.keys(areaData).forEach(pName => {
                html += `<option value="${pName}">${pName}</option>`;
            });
            $prov.html(html);
        }

        // 根据省份加载对应城市
        function loadCity(provName) {
            let html = '<option value="">选择城市</option>';
            if (provName && areaData[provName]) {
                areaData[provName].forEach(city => {
                    html += `<option value="${city}">${city}</option>`;
                });
            }
            $city.html(html);
        }

        initProvince();
        $prov.on("change", function () {
            const p = $(this).val();
            loadCity(p);
        });

        // 密码显隐切换
        $(".eye-toggle").click(function () {
            let targetId = $(this).attr("data-target");
            let inputObj = $("#" + targetId);
            if (inputObj.attr("type") === "password") {
                inputObj.attr("type", "text");
                $(this).text("🙈");
            } else {
                inputObj.attr("type", "password");
                $(this).text("👁");
            }
        });

        // 收款方式切换修改placeholder
        $("select[asp-for='Input.WithdrawMethod']").on("change", function () {
            let selectVal = $(this).val();
            const accountInput = $("#withdrawAccountInput");
            if (selectVal === "支付宝") {
                accountInput.attr("placeholder", "填写支付宝账号");
            } else if (selectVal === "USDT") {
                accountInput.attr("placeholder", "填写 USDT 钱包地址（TRC20/ERC20）");
            } else {
                accountInput.attr("placeholder", "请先选择收款方式");
            }
        });

        // 实时校验登录密码一致性
        function checkLoginPwd() {
            const p1 = $("#pwdLogin").val();
            const p2 = $("#pwdLoginConfirm").val();
            const tip = $("#loginPwdTip");
            if (p2 && p1 !== p2) {
                tip.text("两次输入的登录密码不一致");
            } else {
                tip.text("");
            }
        }
        $("#pwdLogin,#pwdLoginConfirm").on("input blur", checkLoginPwd);

        // 实时校验提款密码一致性
        function checkWithdrawPwd() {
            const p1 = $("#pwdWithdraw").val();
            const p2 = $("#pwdWithdrawConfirm").val();
            const tip = $("#withdrawPwdTip");
            if (p2 && p1 !== p2) {
                tip.text("两次输入的提款密码不一致");
            } else {
                tip.text("");
            }
        }
        $("#pwdWithdraw,#pwdWithdrawConfirm").on("input blur", checkWithdrawPwd);

        // 表单提交兜底校验，阻止非法提交
        $("#regForm").submit(function (e) {
            let loginPwd = $("#pwdLogin").val();
            let loginConfirm = $("#pwdLoginConfirm").val();
            let withdrawPwd = $("#pwdWithdraw").val();
            let withdrawConfirm = $("#pwdWithdrawConfirm").val();
            let canSubmit = true;

            $("#loginPwdTip").text("");
            $("#withdrawPwdTip").text("");

            if (loginPwd !== loginConfirm) {
                $("#loginPwdTip").text("两次输入的登录密码不一致");
                canSubmit = false;
            }
            if (withdrawPwd !== withdrawConfirm) {
                $("#withdrawPwdTip").text("两次输入的提款密码不一致");
                canSubmit = false;
            }

            if (!canSubmit) {
                e.preventDefault();
            }
        });
    </script>
</body>
</html>