@page
@model Pages.Admin.LoginModel
@{
    ViewData["Title"] = "管理员登录";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4">
            <div class="card">
                <div class="card-header text-center">
                    <h4>后台管理系统 - 登录</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div class="mb-3">
                            <label>管理员账号</label>
                            <input asp-for="Input.AdminName" class="form-control" />
                            <span asp-validation-for="Input.AdminName" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label>密码</label>
                            <input asp-for="Input.Password" type="password" class="form-control" />
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>
                        <div class="d-grid">
                            <button class="btn btn-primary">登录</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>