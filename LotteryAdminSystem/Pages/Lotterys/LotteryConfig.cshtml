@page
@model LotteryAdminSystem.Pages.Lotterys.LotteryConfigModel 
@{
    Layout = null;
    ViewData["Title"] = "彩种玩法配置";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>彩种玩法后台配置</title>
    <style>
        table { border-collapse: collapse; width: 80%; margin:20px auto; }
        th,td { border:1px solid #ccc; padding:8px; text-align:center; }
        th { background:#f5f5f5; }
        .box { width:80%; margin:20px auto; }
        input { padding:4px; }
        button { padding:5px 10px; cursor:pointer; }
    </style>
</head>
<body>
    <div class="box">
        <h2>一、彩种管理</h2>
        <form method="post">
            <input type="hidden" name="id" value="0" />
            名称：<input name="name" placeholder="彩种名称" />
            排序：<input name="sort" value="0" />
            <label><input type="checkbox" name="enable" checked />启用</label>
            <button type="submit" formaction="?handler=SaveLottery">新增/保存</button>
        </form>

        <table>
            <tr>
                <th>ID</th>
                <th>名称</th>
                <th>排序</th>
                <th>状态</th>
                <th>操作</th>
            </tr>
            @foreach (var item in Model.LotteryList)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.LotteryName</td>
                    <td>@item.Sort</td>
                    <td>@(item.IsEnable ? "启用" : "禁用")</td>
                    <td>
                        <form method="post" style="display:inline">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button formaction="?handler=DelLottery" onclick="return confirm('确定删除？')">删除</button>
                        </form>
                    </td>
                </tr>
            }
        </table>
    </div>

    <div class="box">
        <h2>二、玩法管理</h2>
        <form method="post">
            <input type="hidden" name="id" value="0" />
            彩种ID：<input name="lotteryId" value="1" />
            玩法名称：<input name="playName" />
            奖金：<input name="bonus" value="0" />
            排序：<input name="sort" value="0" />
            <label><input type="checkbox" name="enable" checked />启用</label>
            <button type="submit" formaction="?handler=SavePlay">新增/保存</button>
        </form>

        <table>
            <tr>
                <th>ID</th>
                <th>所属彩种</th>
                <th>玩法名称</th>
                <th>奖金</th>
                <th>排序</th>
                <th>状态</th>
                <th>操作</th>
            </tr>
            @foreach (var item in Model.PlayList)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Lottery.LotteryName</td>
                    <td>@item.PlayName</td>
                    <td>@item.BonusAmount</td>
                    <td>@item.Sort</td>
                    <td>@(item.IsEnable ? "启用" : "禁用")</td>
                    <td>
                        <form method="post" style="display:inline">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button formaction="?handler=DelPlay" onclick="return confirm('确定删除？')">删除</button>
                        </form>
                    </td>
                </tr>
            }
        </table>
    </div>
</body>
</html>