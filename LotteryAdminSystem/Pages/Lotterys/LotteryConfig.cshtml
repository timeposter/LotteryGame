@page
@model LotteryAdminSystem.Pages.Lotterys.LotteryConfigModel
@{
    Layout = "_Layout";
    ViewData["Menu"] = "lottery";
    ViewData["Title"] = "彩种玩法配置";
}

<div class="container-fluid mt-4">
    <h3 class="mb-4">🎫 彩种玩法配置管理</h3>

    <!-- 彩种新增/编辑弹窗 -->
    <div class="modal fade" id="lotteryModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">彩种编辑</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form method="post" asp-page-handler="SaveLottery">
                    <div class="modal-body">
                        <input type="hidden" name="id" id="lotteryIdInput" value="0" />
                        <div class="mb-3">
                            <label class="form-label">彩种名称</label>
                            <input name="name" id="lotteryNameInput" class="form-control" placeholder="请输入彩种名称" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">排序序号</label>
                            <input name="sort" id="lotterySortInput" class="form-control" value="0" type="number">
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="enable" id="lotteryEnableCheck" checked>
                            <label class="form-check-label">启用该彩种</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                        <button type="submit" class="btn btn-primary">保存</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- 彩种操作区域 -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5>一、彩种基础管理</h5>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#lotteryModal" onclick="resetLotteryForm()">新增彩种</button>
    </div>

    <table class="table table-bordered table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>彩种名称</th>
                <th>排序</th>
                <th>状态</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.LotteryList)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.LotteryName</td>
                    <td>@item.Sort</td>
                    <td>
                        @if (item.IsEnable)
                        {
                            <span class="text-success">✅ 启用</span>
                        }
                        else
                        {
                            <span class="text-danger">❌ 禁用</span>
                        }
                    </td>
                    <td>
                        <button class="btn btn-sm btn-warning" onclick="editLottery(@item.Id, '@item.LotteryName', @item.Sort, @(item.IsEnable ? "true" : "false"))">编辑</button>
                        <form method="post" asp-page-handler="DelLottery" class="d-inline">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button class="btn btn-sm btn-danger" onclick="return confirm('确定要删除该彩种？关联玩法会一并失效！')">删除</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <hr class="my-5">

    <!-- 玩法新增/编辑弹窗 -->
    <div class="modal fade" id="playModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">玩法编辑</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form method="post" asp-page-handler="SavePlay">
                    <div class="modal-body">
                        <input type="hidden" name="id" id="playIdInput" value="0" />
                        <div class="mb-3">
                            <label class="form-label">所属彩种ID</label>
                            <input name="lotteryId" id="playLotteryIdInput" class="form-control" value="1" type="number" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">玩法名称</label>
                            <input name="playName" id="playNameInput" class="form-control" placeholder="请输入玩法名称" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">奖金金额</label>
                            <input name="bonus" id="playBonusInput" class="form-control" value="0" type="decimal">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">排序序号</label>
                            <input name="sort" id="playSortInput" class="form-control" value="0" type="number">
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="enable" id="playEnableCheck" checked>
                            <label class="form-check-label">启用该玩法</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                        <button type="submit" class="btn btn-primary">保存</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- 玩法操作区域 -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5>二、玩法配置管理</h5>
        <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#playModal" onclick="resetPlayForm()">新增玩法</button>
    </div>

    <table class="table table-bordered table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>所属彩种</th>
                <th>玩法名称</th>
                <th>奖金</th>
                <th>排序</th>
                <th>状态</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.PlayList)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Lottery.LotteryName</td>
                    <td>@item.PlayName</td>
                    <td>@item.BonusAmount.ToString("F2")</td>
                    <td>@item.Sort</td>
                    <td>
                        @if (item.IsEnable)
                        {
                            <span class="text-success">✅ 启用</span>
                        }
                        else
                        {
                            <span class="text-danger">❌ 禁用</span>
                        }
                    </td>
                    <td>
                        <button class="btn btn-sm btn-warning" onclick="editPlay(@item.Id, @item.LotteryId, '@item.PlayName', @item.BonusAmount, @item.Sort, @(item.IsEnable ? "true" : "false"))">编辑</button>
                        <form method="post" asp-page-handler="DelPlay" class="d-inline">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button class="btn btn-sm btn-danger" onclick="return confirm('确定删除该玩法？')">删除</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        // 重置彩种弹窗表单
        function resetLotteryForm(){
            document.getElementById("lotteryIdInput").value = "0";
            document.getElementById("lotteryNameInput").value = "";
            document.getElementById("lotterySortInput").value = "0";
            document.getElementById("lotteryEnableCheck").checked = true;
        }
        // 编辑彩种回填数据
        function editLottery(id,name,sort,enable){
            document.getElementById("lotteryIdInput").value = id;
            document.getElementById("lotteryNameInput").value = name;
            document.getElementById("lotterySortInput").value = sort;
            document.getElementById("lotteryEnableCheck").checked = enable;
            var modal = new bootstrap.Modal(document.getElementById('lotteryModal'));
            modal.show();
        }

        // 重置玩法弹窗表单
        function resetPlayForm(){
            document.getElementById("playIdInput").value = "0";
            document.getElementById("playLotteryIdInput").value = "1";
            document.getElementById("playNameInput").value = "";
            document.getElementById("playBonusInput").value = "0";
            document.getElementById("playSortInput").value = "0";
            document.getElementById("playEnableCheck").checked = true;
        }
        // 编辑玩法回填数据
        function editPlay(id,lotteryId,playName,bonus,sort,enable){
            document.getElementById("playIdInput").value = id;
            document.getElementById("playLotteryIdInput").value = lotteryId;
            document.getElementById("playNameInput").value = playName;
            document.getElementById("playBonusInput").value = bonus;
            document.getElementById("playSortInput").value = sort;
            document.getElementById("playEnableCheck").checked = enable;
            var modal = new bootstrap.Modal(document.getElementById('playModal'));
            modal.show();
        }
    </script>
}