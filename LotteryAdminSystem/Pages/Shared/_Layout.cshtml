@using LotteryModels

@{
    string loginName = User.Identity?.Name ?? "";
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>彩票管理后台</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .sidebar {
            width: 220px;
            min-height: 100vh;
            background: #212529;
            position: fixed;
            top: 0;
            left: 0;
            padding-top: 56px;
        }

            .sidebar a {
                color: #adb5bd;
                padding: 12px 20px;
                display: block;
                text-decoration: none;
            }

                .sidebar a.active, .sidebar a:hover {
                    background: #495057;
                    color: #fff;
                }

        .main-content {
            margin-left: 220px;
            padding: 20px;
            padding-top: 70px;
        }

        .top-nav {
            position: fixed;
            left: 220px;
            right: 0;
            height: 56px;
            background: #343a40;
            color: white;
            line-height: 56px;
            padding: 0 20px;
            z-index: 99;
        }
    </style>
</head>
<body>
    <!-- 侧边栏 -->
    <div class="sidebar">
        <div class="text-center text-white py-3 border-bottom border-secondary">
            <h5>彩票管理系统</h5>
        </div>
        <a asp-page="/Index" data-turbo="false" class="@(ViewData["Menu"] == "home" ? "active" : "")">🏠 系统首页</a>
        <a asp-page="/Admin/UserManage" data-turbo="false" class="@(ViewData["Menu"] == "user" ? "active" : "")">👤 用户管理</a>
        <a asp-page="/Admin/FundManage" data-turbo="false" class="@(ViewData["Menu"] == "fund" ? "active" : "")">💰 资金流水</a>
        <a asp-page="/Lotterys/LotteryConfig" data-turbo="false" class="@(ViewData["Menu"] == "lottery" ? "active" : "")">🎫 彩种管理</a>
        <a asp-page="/Lotterys/BetRecordManage" data-turbo="false" class="@(ViewData["Menu"] == "bet" ? "active" : "")">📋 下注记录</a>
        <a asp-page="/Admin/UsdtConfig" data-turbo="false" class="=@(ViewData["Menu"] == "usdt" ? "active" : "")">💰 USDT收款配置</a>
    </div>

    <!-- 顶部导航 -->
    <div class="top-nav d-flex justify-content-between">
        <span>后台管理面板</span>
        <div>
            @if (!string.IsNullOrEmpty(loginName))
            {
                <span>欢迎，@loginName</span>
                <form asp-page="/Admin/Login" asp-page-handler="Logout" method="post" class="d-inline ms-3">
                    <button class="btn btn-sm btn-outline-light">退出登录</button>
                </form>
            }
        </div>
    </div>

    <!-- 主内容区域 -->
    <div class="main-content">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>